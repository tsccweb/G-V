{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(sw.js|manifest.webmanifest|registerSW.js|workbox-.*\\.js|logo.*\\.png|screenshot-.*\\.png)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
